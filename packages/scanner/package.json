{
  "name": "@longcelot-seo/scanner",
  "version": "0.0.1",
  "private": true,
  "description": "AST codebase scanner and URL crawler for longcelot-seo",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@babel/parser": "^7.29.0",
    "@babel/traverse": "^7.29.0",
    "@babel/types": "^7.29.0",
    "@longcelot-seo/core": "workspace:*",
    "@vue/compiler-sfc": "^3.5.30",
    "fast-glob": "^3.3.3"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@types/babel__traverse": "^7.28.0",
    "@types/node": "^20.14.0",
    "tsup": "^8.1.0",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  },
  "files": [
    "dist"
  ]
}
