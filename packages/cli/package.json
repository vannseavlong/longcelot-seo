{
  "name": "longcelot-seo",
  "version": "0.0.3",
  "description": "The SEO engineer's best friend — CLI toolkit for auditing, fixing, and monitoring SEO",
  "keywords": [
    "seo",
    "cli",
    "audit",
    "nextjs",
    "vue",
    "react"
  ],
  "homepage": "https://github.com/vannseavlong/longcelot-seo",
  "repository": {
    "type": "git",
    "url": "https://github.com/vannseavlong/longcelot-seo.git"
  },
  "license": "MIT",
  "author": "Vannseavlong",
  "type": "module",
  "main": "./dist/bin/lseo.cjs",
  "module": "./dist/bin/lseo.js",
  "types": "./dist/bin/lseo.d.ts",
  "bin": {
    "lseo": "./dist/bin/lseo.js"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "postinstall": "node -e \"const fs=require('fs');if(fs.existsSync('./dist/scripts/postinstall.cjs')){require('./dist/scripts/postinstall.cjs')}\""
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0",
    "cosmiconfig": "^9.0.0",
    "figlet": "^1.7.0",
    "ora": "^8.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/figlet": "^1.5.8",
    "@types/node": "^20.14.0",
    "tsup": "^8.1.0",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18.0.0"
  }
}
